---
/**
 * FontShowcase - 中文字体对比展示组件
 * 加载 8 款中文字体并展示相同内容的渲染效果
 */

const sampleText = `在这个数字化的时代，每个人都有自己的博客角落。这里记录着代码与思考，也藏着生活的碎片。字体不仅仅是文字的外衣，它是阅读体验的灵魂。一段好的文字，配上合适的字体，就像一首曲子找到了它的乐器。We also mix in some English to test 中英混排的效果——this is very common in 技术博客。`;

const fonts = [
  {
    id: 1,
    name: "Noto Sans SC",
    nameCn: "思源黑体",
    family: "'Noto Sans SC', sans-serif",
    weights: "400;700",
    style: "无衬线 · 黑体",
    note: "中文世界的 Inter，干净中性专业。Google Fonts 分包加载速度最快，和大多数英文 sans-serif 搭配和谐。最安全的选择。",
    recommended: true,
  },
  {
    id: 2,
    name: "Noto Serif SC",
    nameCn: "思源宋体",
    family: "'Noto Serif SC', serif",
    weights: "400;700",
    style: "衬线 · 宋体",
    note: "传统印刷质感，带有书卷气。适合文学、随笔类内容。小字号屏幕可读性略逊于黑体，但标题效果出色。",
    recommended: false,
  },
  {
    id: 3,
    name: "LXGW WenKai",
    nameCn: "霞鹜文楷",
    family: "'LXGW WenKai', serif",
    weights: "400",
    style: "楷书 · 手写感",
    note: "源自 FONTWORKS Klee One，温暖的手写楷书风格。长时间阅读不疲劳，文艺博客首选。中英混排时英文也有衬线风格，整体协调。",
    recommended: true,
  },
  {
    id: 4,
    name: "ZCOOL XiaoWei",
    nameCn: "站酷小薇",
    family: "'ZCOOL XiaoWei', serif",
    weights: "400",
    style: "衬线 · 纤细优雅",
    note: "笔画纤细优雅，有书签题字的感觉。适合标题和短文本，作为正文长时间阅读笔画偏细。",
    recommended: false,
  },
  {
    id: 5,
    name: "ZCOOL QingKe HuangYou",
    nameCn: "站酷庆科黄油体",
    family: "'ZCOOL QingKe HuangYou', sans-serif",
    weights: "400",
    style: "无衬线 · 圆润粗犷",
    note: "圆润饱满，有海报感。适合大标题和品牌展示，不适合正文。",
    recommended: false,
  },
  {
    id: 6,
    name: "Ma Shan Zheng",
    nameCn: "马善政毛笔楷书",
    family: "'Ma Shan Zheng', cursive",
    weights: "400",
    style: "书法 · 毛笔楷书",
    note: "真实的毛笔笔触感，有书法韵味。适合装饰性标题或引用块，正文阅读会过于花哨。",
    recommended: false,
  },
  {
    id: 7,
    name: "Long Cang",
    nameCn: "龙藏",
    family: "'Long Cang', cursive",
    weights: "400",
    style: "手写 · 行书",
    note: "流畅的行书手写风格，有个人笔记的感觉。适合个性化引用或签名，不适合正文。",
    recommended: false,
  },
  {
    id: 8,
    name: "Liu Jian Mao Cao",
    nameCn: "柳建毛草",
    family: "'Liu Jian Mao Cao', cursive",
    weights: "400",
    style: "书法 · 狂草",
    note: "极具艺术感的狂草风格，辨识度极高但可读性最低。纯装饰用途，适合特殊设计场景。",
    recommended: false,
  },
];
---

<!-- Load all Chinese web fonts for comparison -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700&family=Noto+Serif+SC:wght@400;700&family=ZCOOL+XiaoWei&family=ZCOOL+QingKe+HuangYou&family=Ma+Shan+Zheng&family=Long+Cang&family=Liu+Jian+Mao+Cao&display=swap"
  rel="stylesheet"
/>
<link
  href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.7.0/style.css"
  rel="stylesheet"
/>

<div class="font-showcase">
  {
    fonts.map(font => (
      <article
        class:list={[
          "font-card",
          { "font-card--recommended": font.recommended },
        ]}
      >
        <div class="font-card__header">
          <span class="font-card__id">#{font.id}</span>
          <div class="font-card__name">
            <span class="font-card__name-cn" style={`font-family: ${font.family}`}>
              {font.nameCn}
            </span>
            <span class="font-card__name-en">{font.name}</span>
          </div>
          <span class="font-card__style">{font.style}</span>
          {font.recommended && (
            <span class="font-card__badge">推荐</span>
          )}
        </div>

        <div class="font-card__preview">
          <h3 style={`font-family: ${font.family}`}>
            博客标题示例：技术、生活与思考
          </h3>
          <p style={`font-family: ${font.family}`}>
            {sampleText}
          </p>
        </div>

        <p class="font-card__note">{font.note}</p>
      </article>
    ))
  }
</div>

<style>
  .font-showcase {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 2rem 0;
  }

  .font-card {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1.5rem;
    background: var(--muted);
    transition: border-color 0.2s;
  }

  .font-card--recommended {
    border-color: var(--accent);
    border-width: 2px;
  }

  .font-card__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .font-card__id {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--accent);
    color: var(--accent-foreground);
    font-size: 0.875rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .font-card__name {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .font-card__name-cn {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--foreground);
  }

  .font-card__name-en {
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }

  .font-card__style {
    font-size: 0.75rem;
    color: var(--muted-foreground);
    padding: 0.25rem 0.5rem;
    background: var(--background);
    border-radius: 0.25rem;
    border: 1px solid var(--border);
  }

  .font-card__badge {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent-foreground);
    background: var(--accent);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }

  .font-card__preview {
    margin-bottom: 1rem;
  }

  .font-card__preview h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--foreground);
  }

  .font-card__preview p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--foreground);
  }

  .font-card__note {
    font-size: 0.85rem;
    color: var(--muted-foreground);
    line-height: 1.6;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .font-card {
      padding: 1rem;
    }

    .font-card__header {
      gap: 0.5rem;
    }
  }
</style>
