---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-6">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Gavin's <span class="text-accent">Blog</span>
      </h1>
      <a
        target="_blank"
        href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
        class="inline-block"
        aria-label="RSS Feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
        Hello, everyone! Welcome to my personal blog.
      </p>
      <blockquote
        id="daily-quote"
        class="mt-4 border-s-accent/80 ps-4 text-sm italic opacity-80"
      >
        <p id="quote-text">Loading...</p>
        <footer id="quote-author" class="mt-1 text-xs not-italic opacity-60"></footer>
      </blockquote>
      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }

    // 一言 API: https://hitokoto.cn
    // 每次首页加载 fetch 一次,同会话 sessionStorage 缓存(避免站内 SPA 切换名言闪)
    // 浏览器/标签页关闭再打开 → 新的一句
    const quoteEl = document.getElementById("quote-text");
    const authorEl = document.getElementById("quote-author");
    if (!quoteEl || !authorEl) return;

    // 后备名言(API 失败时随机选 1 条)
    const fallbackQuotes = [
      { text: "代码是写给人看的，只是恰好能被机器执行。", author: "Harold Abelson" },
      { text: "保持饥饿，保持愚蠢。", author: "Steve Jobs" },
      { text: "Talk is cheap. Show me the code.", author: "Linus Torvalds" },
      { text: "千里之行，始于足下。", author: "老子" },
      { text: "The best way to predict the future is to invent it.", author: "Alan Kay" },
    ];

    function setQuote(text: string, author: string) {
      quoteEl!.textContent = `"${text}"`;
      authorEl!.textContent = `— ${author || "匿名"}`;
    }

    const CACHE_KEY = "hitokoto:cache:v1";

    // 1) 先看 sessionStorage 有没有(同会话内不重复请求)
    const cached = sessionStorage.getItem(CACHE_KEY);
    if (cached) {
      try {
        const data = JSON.parse(cached);
        setQuote(data.hitokoto, data.from_who || data.from || "");
        return;
      } catch (e) {
        // 缓存坏了,继续 fetch
      }
    }

    // 2) 没缓存 → fetch 一言 API
    // c= 不传 → 全部类型随机;b 哲学 / d 文学 / i 互联网 / k 梗
    // 不限定类型,每次都不一样
    const url = "https://v1.hitokoto.cn/?encode=json&ts=" + Date.now();
    fetch(url, { method: "GET" })
      .then((r) => r.json())
      .then((data) => {
        if (data && data.hitokoto) {
          sessionStorage.setItem(CACHE_KEY, JSON.stringify(data));
          setQuote(data.hitokoto, data.from_who || data.from || "");
        } else {
          throw new Error("empty response");
        }
      })
      .catch(() => {
        // API 失败 → 随机选一条后备
        const f = fallbackQuotes[Math.floor(Math.random() * fallbackQuotes.length)];
        setQuote(f.text, f.author);
      });
  });
</script>
